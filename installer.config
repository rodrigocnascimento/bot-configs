# OpenCode Installer Configuration
# ==================================
# Edit this file to add/remove folders from the default installation
# Changes take effect immediately - no need to regenerate the installer

# Default folders to install (space-separated)
DEFAULT_FOLDERS="commands rules skills docs .cursor"

# GitHub repository information
GITHUB_USER="rodrigocnascimento"
GITHUB_REPO="bot-configs"
GITHUB_BRANCH="main"

# Base URL for raw GitHub content
RAW_URL="https://raw.githubusercontent.com/${GITHUB_USER}/${GITHUB_REPO}/${GITHUB_BRANCH}"

# API URL for fetching directory contents (for recursive folder download)
API_URL="https://api.github.com/repos/${GITHUB_USER}/${GITHUB_REPO}/contents"
